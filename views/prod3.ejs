<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eliminar Producto</title>
    <link rel="stylesheet" href="/stylesheets/elimipro.css"> 
    <link rel="shortcut icon" type="image/x-icon" href="/images/images.ico">
</head>
<body> 
    <div class="T1">
        <h3>¿Está seguro de eliminar este producto?</h3>
        <form action="/elimyprod/<%= productos.id %>" method="get">
            <h4><%= productos.nombre %></h4>
            <h4><%= productos.codigo %></h4>
            <h4><%= productos.precio %></h4>
            <h4><%= productos.empresa %></h4>
            <h4><%= productos.sexo %></h4>
            <h4><%= productos.descripcion %></h4>
            <input type="submit" value="Eliminar Producto">
        </form>
    </div>
</body>
</html>