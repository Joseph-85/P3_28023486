<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Producto</title>
    <link rel="stylesheet" href="/stylesheets/increpro.css"> 
    <link rel="shortcut icon" type="image/x-icon" href="/images/images.ico">
</head>
<body>
    <div  class="formulario2">
        <h1>Editar Producto</h1>
        <form action="/Actualyprod/<%= productos.id %>" method="post">
            <div class="i1">
                <div class="i1">
            <input type="text" name="nombre" id="nombre" value="<%= productos.nombre %>" required maxlength="25" minlength="3">
        </div> 
        <div class="i1">
            <input type="number" name="codigo" id="codigo" value="<%= productos.codigo %>" required>
        </div>
        <div class="i1">
            <input type="number" name="precio" id="precio" value="<%= productos.precio %>" required>
        </div> 
            <div class="i1">
            <input type="text" name="empresa" id="empresa" value="<%= productos.empresa %>" required maxlength="25" minlength="4">
            </div>
          
            <div class="i1">
            <input type="textarea" name="descripcion" id="descripcion" value="<%= productos.descripcion %>" maxlength="60" minlength="10">
        </div> 
        <select name="sexo" id="sexo">
            <option value="">--Ingrese para que genero es--</option>
            <option value="Mujeres">Mujeres</option>
            <option value="Hombres">Hombres</option>
        </select>
       
    </div> 
    <input type="submit" value="Actualizar Producto">   
    </form>
    </div>
</body>
</html>